services:
  radarr:
    image: lscr.io/linuxserver/radarr:{{ services.radarr.version }}
    container_name: radarr
    env_file: .env
    volumes:
      - /opt/docker/standard/arr/radarr:/config
      - /media:/media
    ports:
      - 7878:7878
    restart: unless-stopped
    labels:
      glance.name: Radarr
      glance.icon: sh:radarr
      glance.url: https://{{ services.radarr.subdomain | default('radarr') }}.{{ domain }}
      glance.hide: false
networks:
  default:
    external: true
    name: media_network
