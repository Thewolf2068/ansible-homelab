services:
  homarr:
    container_name: homarr
    image: ghcr.io/homarr-labs/homarr:{{ services.homarr.version }}
    restart: unless-stopped
    env_file: .env
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock # Optional, only if you want docker integration
      - /opt/docker/standard/homarr/appdata:/appdata
    ports:
      - '7575:7575'


networks:
  default:
    external: true
    name: dashboard_network
