services:
  dockge:
    image: louislam/dockge:${DOCKGE_VERSION}
    restart: unless-stopped
    ports:
      - "5001:5001"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - /opt/docker/privileged/dockge:/app/data
      - /opt/stacks:/opt/stacks
    environment:
      - DOCKGE_STACKS_DIR=/opt/stacks
    labels:
      glance.name: Dockge
      glance.icon: sh:dockge
      glance.url: https://{{ services.dockge.subdomain | default('dockge') }}.{{ domain }}
      glance.hide: false
