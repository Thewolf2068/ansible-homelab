{

  "tools": {
    "allow": ["web_search", "web_fetch", "group:fs", "group:memory"]
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-2.5-flash-lite"
      },
      "models": {
        "deepseek/deepseek-chat": { "alias": "deepseek-chat" },
        "deepseek/deepseek-reasoner": { "alias": "deepseek-reasoner" },
        "anthropic/claude-haiku-4-5": { "alias": "haiku" },
        "google/gemini-2.5-flash-lite": { "alias": "flash" }
      },
      "workspace": "/data/workspace",
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "deepseek": {
        "baseUrl": "https://api.deepseek.com",
        "apiKey": "{{ OPENCLAW_DEEPSEEK_API_KEY }}",
        "api": "openai-completions",
        "models": [
          {
            "id": "deepseek-chat",
            "name": "DeepSeek V3",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      }
    }
  }
}
